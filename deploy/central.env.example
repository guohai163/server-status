# PostgreSQL connection URI for a login role that inherits server_status_writer.
SERVER_STATUS_DATABASE_URL=postgres://server_status_app:change-me@postgres.example:5432/server_status_db?sslmode=disable

# Generate with: openssl rand -base64 48
SERVER_STATUS_ADMIN_TOKEN=change-me-to-at-least-32-random-characters
SERVER_STATUS_LISTEN_ADDR=:8080

# Pin the published central image used by compose.yaml.
SERVER_STATUS_CENTRAL_IMAGE=ghcr.io/guohai163/server-status-central:0.4.2
